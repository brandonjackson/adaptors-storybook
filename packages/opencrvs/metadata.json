{
  "vendor": "OpenCRVS",
  "product": "OpenCRVS Civil Registration",
  "homepage": "https://www.opencrvs.org",
  "status": "partial",

  "apiStyle": "mixed",
  "baseUrls": [
    "https://gateway.farajaland.opencrvs.org"
  ],

  "auth": {
    "schemes": ["bearer", "jwt"],
    "docs": "https://documentation.opencrvs.org/technology/interoperability"
  },

  "sources": [
    {
      "kind": "docs-index",
      "url": "https://documentation.opencrvs.org/",
      "notes": "OpenCRVS documentation hub"
    },
    {
      "kind": "docs-page",
      "url": "https://documentation.opencrvs.org/technology/interoperability/integrating-with-opencrvs",
      "notes": "Integration / API guide"
    },
    {
      "kind": "graphql-schema",
      "url": "https://gateway.farajaland.opencrvs.org/graphql",
      "introspection": true,
      "notes": "GraphQL gateway endpoint (introspection on demo)"
    },
    {
      "kind": "sdk-repo",
      "url": "https://github.com/opencrvs/opencrvs-core",
      "language": "typescript",
      "notes": "OpenCRVS core monorepo"
    },
    {
      "kind": "sandbox",
      "url": "https://login.farajaland.opencrvs.org",
      "notes": "Farajaland reference deployment"
    }
  ],

  "webhooks": {
    "supported": true,
    "docs": "https://documentation.opencrvs.org/technology/interoperability/webhook-api"
  },

  "notes": "Primarily GraphQL gateway plus FHIR-shaped resources internally."
}
