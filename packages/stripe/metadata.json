{
  "vendor": "Stripe",
  "product": "Stripe API",
  "homepage": "https://stripe.com",
  "status": "partial",

  "apiStyle": "rest",
  "baseUrls": ["https://api.stripe.com/v1"],

  "auth": {
    "schemes": ["bearer", "api-key"],
    "docs": "https://docs.stripe.com/api/authentication"
  },

  "sources": [
    {
      "kind": "openapi",
      "url": "https://raw.githubusercontent.com/stripe/openapi/master/openapi/spec3.json",
      "format": "json",
      "version": "3.0",
      "notes": "Official Stripe OpenAPI spec"
    },
    {
      "kind": "sdk-repo",
      "url": "https://github.com/stripe/stripe-node",
      "language": "typescript",
      "notes": "Official Stripe Node SDK"
    },
    {
      "kind": "docs-index",
      "url": "https://docs.stripe.com/api"
    },
    {
      "kind": "changelog",
      "url": "https://docs.stripe.com/changelog"
    }
  ],

  "webhooks": {
    "supported": true,
    "docs": "https://docs.stripe.com/webhooks"
  },

  "notes": "Bearer auth uses the secret API key directly."
}
